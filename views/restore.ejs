<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Crontab UI</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" crossorigin="anonymous">
<script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="script.js"></script>
<script type="text/javascript">
	var crontabs = [];
	var routes = [];
	document.addEventListener('DOMContentLoaded', function() {
		var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
		tooltipTriggerList.map(function (el) { return new bootstrap.Tooltip(el); });
		crontabs = JSON.parse('<%- crontabs.replace(/\\\\/g, "\\\\\\\\").replace(/\\\"/g,"\\\\\"").replace(/\'/g,"\\\'") %>');
		routes = JSON.parse('<%- routes %>');
	});
</script>
</head>
<body>
<%- include('navbar.ejs') -%>
<div class="container">
	<h2><%= db %></h2>
	<table class="table">
	<tr>
		<th>Id</th>
		<th></th>
		<th>Job</th>
		<th>Time</th>
		<th>Last Modified</th>
	</tr>
	<% var index = 1 %>
	<% JSON.parse(crontabs).forEach(function(crontab){ %>
		<% if (!crontab.stopped) { %>
			<tr>
		<% } else { %>
			<tr class="table-primary">
		<% } %>

				<td>
					<%= index %>.
					<% index += 1 %>
					<%= crontab._id %>
				</td>

				<td>
					<% if (crontab.name) { %>
					<a class="btn btn-sm" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= crontab.name %>"><i class="bi bi-info-circle"></i></a>
					<% } %>
				</td>
				<td><%= crontab.command %></td>
				<td><%= crontab.schedule %></td>
				<td><%= crontab.timestamp %></td>
			</tr>
	<% }); %>



	</table>
	<a class="btn btn-primary" onclick="restore_backup('<%= db %>')"><i class="bi bi-arrow-counterclockwise"></i> Restore</a>
	<a class="btn btn-danger" onclick="delete_backup('<%= db %>')"><i class="bi bi-trash"></i> Delete</a>
</div>
<%- include('popup.ejs') -%>
</body>
</html>
